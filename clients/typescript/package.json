{
  "name": "@agentegrity/workspace",
  "version": "0.6.0",
  "private": true,
  "description": "Workspace root for @agentegrity/* TypeScript packages.",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '@agentegrity/*' build",
    "typecheck": "bun run --filter '@agentegrity/*' typecheck",
    "test": "bun run --filter '@agentegrity/*' test && bun test test/",
    "test:parity": "bun test test/",
    "test:coverage": "bun test --coverage",
    "check-coverage": "bun run scripts/check-coverage.ts",
    "clean": "bun run --filter '@agentegrity/*' clean",
    "check-versions": "tsx scripts/check-versions.ts"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.0.0",
    "@agentegrity/client": "workspace:*",
    "@agentegrity/claude-sdk": "workspace:*",
    "@agentegrity/langchain": "workspace:*",
    "@agentegrity/openai-agents": "workspace:*",
    "@agentegrity/crewai": "workspace:*",
    "@agentegrity/google-adk": "workspace:*",
    "@agentegrity/vercel-ai": "workspace:*"
  },
  "engines": {
    "node": ">=18"
  }
}
