{
  "name": "@agentegrity/crewai",
  "version": "0.5.3",
  "description": "Zero-config agentegrity adapter for CrewAI JS. Mirrors the Python agentegrity.crewai module.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": { "import": "./dist/index.js", "types": "./dist/index.d.ts" } },
  "files": ["dist", "src", "README.md"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "AGENTEGRITY_OFFLINE=1 node --test --import tsx src/*.test.ts",
    "clean": "rm -rf dist"
  },
  "keywords": ["agentegrity", "crewai", "agent", "security", "observability"],
  "dependencies": {
    "@agentegrity/client": "0.5.3"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "tsx": "^4.7.0",
    "@types/node": "^20.0.0"
  },
  "engines": { "node": ">=18" },
  "homepage": "https://github.com/cogensec/agentegrity-framework/tree/main/clients/typescript/packages/crewai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cogensec/agentegrity-framework.git",
    "directory": "clients/typescript/packages/crewai"
  },
  "bugs": { "url": "https://github.com/cogensec/agentegrity-framework/issues" }
}
